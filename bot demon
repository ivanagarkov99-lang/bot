from telegram import Update
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, filters, ContextTypes
import random

TOKEN = "8737358022:AAH-78pW9z-M91gF2Pq1mPOL6i-9VZwyV9s"

# пользователи с включенным режимом вопросов
questions_enabled = set()

# /start
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        'Привет, я бот созданный для Чата чернилок, что бы узнать мои команды напиши "/help" что бы узнать что я умею, Разработчик бота: @Komarix_Original'
    )

# /help
async def help_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "Доступные списки команд:\n"
        "1. Кинуть кубик (бета) - ты бросаешь кубик на разное количество метров\n"
        "2. Включить вопросы - Могу ответить на ваш любой вопрос, но могу отвечать только Да или Нет (написав Выключить вопрос я перестаю отвечать)"
    )

# обработка сообщений
async def reply(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text.lower()
    user_obj = update.message.from_user

    # @username или имя
    user = f"@{user_obj.username}" if user_obj.username else user_obj.first_name

    # 🎲 Кинуть кубик
    if "кинуть кубик" in text:
        distance = random.randint(1, 100)
        await update.message.reply_text(f"{user} кинул кубик на {distance} метров 🎲")

    # 🧠 Включить вопросы
    elif "включить вопросы" in text:
        questions_enabled.add(user_obj.id)
        await update.message.reply_text("Режим вопросов включен ✅")

    # ❌ Выключить вопросы
    elif "выключить вопрос" in text:
        questions_enabled.discard(user_obj.id)
        await update.message.reply_text("Режим вопросов выключен ❌")

    # ❓ Да / Нет
    elif user_obj.id in questions_enabled:
        answer = random.choice(["Да ✅", "Нет ❌"])
        await update.message.reply_text(answer)

# запуск
app = ApplicationBuilder().token(TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(CommandHandler("help", help_command))
app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, reply))

print("Бот запущен...")

app.run_polling()
